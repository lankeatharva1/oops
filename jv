7. Write a Java program to calculate final result of students using method overloading and inheritance.
Accept multiple subject marks from the user and perform the following:
• Calculate total and percentage using overloaded methods
• Implement grade calculation using inheritance
• Display detailed result including marks, percentage, grade, and remarks
• Sort students based on percentage

import java.util.Scanner;

// Parent Class
class Student {

    String name;
    int rollNo;
    int marks[];
    int total;
    double percentage;

    // Constructor
    Student(String name, int rollNo, int subjects) {

        this.name = name;
        this.rollNo = rollNo;
        marks = new int[subjects];
    }

    // Accept Marks
    void getMarks(Scanner sc) {

        System.out.println("Enter marks of subjects:");

        for (int i = 0; i < marks.length; i++) {
            marks[i] = sc.nextInt();
        }
    }

    // Method Overloading for Total Calculation
    int calculateTotal(int a, int b) {
        return a + b;
    }

    int calculateTotal(int a, int b, int c) {
        return a + b + c;
    }

    int calculateTotal(int arr[]) {

        int sum = 0;

        for (int i = 0; i < arr.length; i++) {
            sum += arr[i];
        }

        return sum;
    }

    // Percentage Calculation
    double calculatePercentage() {

        total = calculateTotal(marks);

        percentage = (double) total / (marks.length);

        return percentage;
    }
}

// Child Class using Inheritance
class Result extends Student {

    String grade;
    String remarks;

    // Constructor
    Result(String name, int rollNo, int subjects) {
        super(name, rollNo, subjects);
    }

    // Grade Calculation
    void calculateGrade() {

        if (percentage >= 75) {
            grade = "A";
            remarks = "Excellent";
        } else if (percentage >= 60) {
            grade = "B";
            remarks = "Very Good";
        } else if (percentage >= 50) {
            grade = "C";
            remarks = "Good";
        } else if (percentage >= 35) {
            grade = "D";
            remarks = "Pass";
        } else {
            grade = "F";
            remarks = "Fail";
        }
    }

    // Display Result
    void displayResult() {

        System.out.println("\n----------------------------");
        System.out.println("Student Name : " + name);
        System.out.println("Roll No      : " + rollNo);

        System.out.print("Marks        : ");

        for (int m : marks) {
            System.out.print(m + " ");
        }

        System.out.println("\nTotal Marks  : " + total);
        System.out.println("Percentage   : " + percentage);
        System.out.println("Grade        : " + grade);
        System.out.println("Remarks      : " + remarks);
    }
}

// Main Class
class StudentResultSystem {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Enter number of students: ");
        int n = sc.nextInt();

        System.out.print("Enter number of subjects: ");
        int subjects = sc.nextInt();

        Result students[] = new Result[n];

        // Input Student Details
        for (int i = 0; i < n; i++) {

            sc.nextLine();

            System.out.println("\nEnter details of Student " + (i + 1));

            System.out.print("Enter Name: ");
            String name = sc.nextLine();

            System.out.print("Enter Roll No: ");
            int roll = sc.nextInt();

            students[i] = new Result(name, roll, subjects);

            students[i].getMarks(sc);

            students[i].calculatePercentage();

            students[i].calculateGrade();
        }

        // Sorting based on Percentage
        for (int i = 0; i < n - 1; i++) {

            for (int j = i + 1; j < n; j++) {

                if (students[i].percentage < students[j].percentage) {

                    Result temp = students[i];
                    students[i] = students[j];
                    students[j] = temp;
                }
            }
        }

        // Display Sorted Results
        System.out.println("\n===== STUDENT RESULT =====");

        for (int i = 0; i < n; i++) {
            students[i].displayResult();
        }
    }
}
