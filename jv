5. Write Java program to calculate area of triangle, square & circle using function overloading.
Function parameter accept from user (Use function Overloading concepts and Inheritance).

import java.util.Scanner;

// Parent Class
class Shape {

    // Function Overloading

    // Area of Square
    void area(int side) {
        int squareArea = side * side;
        System.out.println("Area of Square = " + squareArea);
    }

    // Area of Circle
    void area(double radius) {
        double circleArea = 3.14 * radius * radius;
        System.out.println("Area of Circle = " + circleArea);
    }

    // Area of Triangle
    void area(double base, double height) {
        double triangleArea = 0.5 * base * height;
        System.out.println("Area of Triangle = " + triangleArea);
    }
}

// Child Class using Inheritance
class CalculateArea extends Shape {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        // Object of Child Class
        CalculateArea obj = new CalculateArea();

        // Square
        System.out.print("Enter side of square: ");
        int side = sc.nextInt();
        obj.area(side);

        // Circle
        System.out.print("Enter radius of circle: ");
        double radius = sc.nextDouble();
        obj.area(radius);

        // Triangle
        System.out.print("Enter base of triangle: ");
        double base = sc.nextDouble();

        System.out.print("Enter height of triangle: ");
        double height = sc.nextDouble();

        obj.area(base, height);
    }
}

