2. Implement Employee class using following Concepts
All types of Constructors
• Static variables and instance variables
• Static blocks and instance blocks
• Static methods and instance methods
• Method Overloading


class Employee {

    // Static Variable
    static String companyName;

    // Instance Variables
    int empId;
    String empName;
    double salary;

    // Static Block
    static {
        companyName = "Tech Solutions";
        System.out.println("Static Block Executed");
    }

    // Instance Block
    {
        System.out.println("Instance Block Executed");
    }

    // Default Constructor
    Employee() {
        empId = 0;
        empName = "Not Assigned";
        salary = 0.0;
        System.out.println("Default Constructor Called");
    }

    // Parameterized Constructor
    Employee(int id, String name, double sal) {
        empId = id;
        empName = name;
        salary = sal;
        System.out.println("Parameterized Constructor Called");
    }

    // Copy Constructor
    Employee(Employee e) {
        empId = e.empId;
        empName = e.empName;
        salary = e.salary;
        System.out.println("Copy Constructor Called");
    }

    // Instance Method
    void display() {
        System.out.println("Employee ID   : " + empId);
        System.out.println("Employee Name : " + empName);
        System.out.println("Salary        : " + salary);
        System.out.println("Company       : " + companyName);
    }

    // Static Method
    static void changeCompany(String cname) {
        companyName = cname;
        System.out.println("Company Changed to : " + companyName);
    }

    // Method Overloading
    void calculateSalary() {
        System.out.println("Salary : " + salary);
    }

    void calculateSalary(double bonus) {
        System.out.println("Salary with Bonus : " + (salary + bonus));
    }

    void calculateSalary(double bonus, double deduction) {
        System.out.println("Final Salary : " + (salary + bonus - deduction));
    }

    // Main Method
    public static void main(String[] args) {

        // Default Constructor
        Employee e1 = new Employee();

        System.out.println();

        // Parameterized Constructor
        Employee e2 = new Employee(101, "Atharva", 50000);

        System.out.println();

        // Copy Constructor
        Employee e3 = new Employee(e2);

        System.out.println();

        // Display Details
        e1.display();

        System.out.println();

        e2.display();

        System.out.println();

        e3.display();

        System.out.println();

        // Static Method
        Employee.changeCompany("Infosys");

        System.out.println();

        // Method Overloading
        e2.calculateSalary();

        e2.calculateSalary(5000);

        e2.calculateSalary(5000, 2000);
    }
