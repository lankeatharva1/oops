6. Write a Java program to calculate salary of employees using method overloading and inheritance.
Include different employee types (Manager, Developer, Intern) with additional allowances and bonuses. Accept
input from user and display detailed salary breakdown.
import java.util.Scanner;

// Parent Class
class Employee {

    String name;
    double basicSalary;

    // Constructor
    Employee(String name, double basicSalary) {
        this.name = name;
        this.basicSalary = basicSalary;
    }

    // Method Overloading
    double calculateSalary() {
        return basicSalary;
    }

    double calculateSalary(double allowance) {
        return basicSalary + allowance;
    }

    double calculateSalary(double allowance, double bonus) {
        return basicSalary + allowance + bonus;
    }

    // Display Method
    void display(double totalSalary) {
        System.out.println("Employee Name : " + name);
        System.out.println("Basic Salary  : " + basicSalary);
        System.out.println("Total Salary  : " + totalSalary);
    }
}

// Child Class Manager
class Manager extends Employee {

    double allowance;
    double bonus;

    Manager(String name, double basicSalary, double allowance, double bonus) {
        super(name, basicSalary);
        this.allowance = allowance;
        this.bonus = bonus;
    }

    void showSalary() {
        double total = calculateSalary(allowance, bonus);

        System.out.println("\n----- Manager Salary Details -----");
        display(total);
        System.out.println("Allowance     : " + allowance);
        System.out.println("Bonus         : " + bonus);
    }
}

// Child Class Developer
class Developer extends Employee {

    double allowance;

    Developer(String name, double basicSalary, double allowance) {
        super(name, basicSalary);
        this.allowance = allowance;
    }

    void showSalary() {
        double total = calculateSalary(allowance);

        System.out.println("\n----- Developer Salary Details -----");
        display(total);
        System.out.println("Allowance     : " + allowance);
    }
}

// Child Class Intern
class Intern extends Employee {

    Intern(String name, double basicSalary) {
        super(name, basicSalary);
    }

    void showSalary() {
        double total = calculateSalary();

        System.out.println("\n----- Intern Salary Details -----");
        display(total);
    }
}

// Main Class
class SalarySystem {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        // Manager Input
        System.out.println("Enter Manager Details");
        System.out.print("Name: ");
        String mName = sc.nextLine();

        System.out.print("Basic Salary: ");
        double mSalary = sc.nextDouble();

        System.out.print("Allowance: ");
        double mAllowance = sc.nextDouble();

        System.out.print("Bonus: ");
        double mBonus = sc.nextDouble();

        sc.nextLine();

        // Developer Input
        System.out.println("\nEnter Developer Details");
        System.out.print("Name: ");
        String dName = sc.nextLine();

        System.out.print("Basic Salary: ");
        double dSalary = sc.nextDouble();

        System.out.print("Allowance: ");
        double dAllowance = sc.nextDouble();

        sc.nextLine();

        // Intern Input
        System.out.println("\nEnter Intern Details");
        System.out.print("Name: ");
        String iName = sc.nextLine();

        System.out.print("Basic Salary: ");
        double iSalary = sc.nextDouble();

        // Object Creation
        Manager m = new Manager(mName, mSalary, mAllowance, mBonus);
        Developer d = new Developer(dName, dSalary, dAllowance);
        Intern i = new Intern(iName, iSalary);

        // Display Salary Details
        m.showSalary();
        d.showSalary();
        i.showSalary();
    }
}

