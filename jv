1. Implement Student class using following Concepts
• All types of Constructors
• Static variables and instance variables
• Static blocks and instance blocks
• Static methods and instance methods

class Student {

    // Static variable
    static String collegeName;

    // Instance variables
    int rollNo;
    String name;
    double marks;

    // Static Block
    static {
        collegeName = "ABC College";
        System.out.println("Static Block Executed");
    }

    // Instance Block
    {
        System.out.println("Instance Block Executed");
    }

    // Default Constructor
    Student() {
        rollNo = 0;
        name = "Not Assigned";
        marks = 0.0;
        System.out.println("Default Constructor Called");
    }

    // Parameterized Constructor
    Student(int r, String n, double m) {
        rollNo = r;
        name = n;
        marks = m;
        System.out.println("Parameterized Constructor Called");
    }

    // Copy Constructor
    Student(Student s) {
        rollNo = s.rollNo;
        name = s.name;
        marks = s.marks;
        System.out.println("Copy Constructor Called");
    }

    // Instance Method
    void display() {
        System.out.println("Roll No : " + rollNo);
        System.out.println("Name    : " + name);
        System.out.println("Marks   : " + marks);
        System.out.println("College : " + collegeName);
    }

    // Static Method
    static void changeCollege(String cname) {
        collegeName = cname;
        System.out.println("College Changed to : " + collegeName);
    }

    // Main Method
    public static void main(String[] args) {

        // Calling Default Constructor
        Student s1 = new Student();

        System.out.println();

        // Calling Parameterized Constructor
        Student s2 = new Student(101, "Atharva", 89.5);

        System.out.println();

        // Calling Copy Constructor
        Student s3 = new Student(s2);

        System.out.println();

        // Display Student Details
        s1.display();

        System.out.println();

        s2.display();

        System.out.println();

        s3.display();

        System.out.println();

        // Calling Static Method
        Student.changeCollege("XYZ College");

        System.out.println();

        s2.display();
    }
}



